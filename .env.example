# Use /api in dev so Vite proxies to the backend (works with ngrok on port 3099).
# For production build, use your public API URL (see .env.production.example).
VITE_API_URL=/api
VITE_APP_URL=http://localhost:3099

# ngrok: tunnel port 3099 only, keep VITE_API_URL=/api, run pubmap-backend on 8099 locally.
# Optional: second tunnel for 8099 and set VITE_API_URL=https://YOUR-API.ngrok-free.app/api

